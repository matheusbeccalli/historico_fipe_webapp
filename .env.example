# FIPE Price Tracker - Environment Variables
# Copy this file to .env and update with your actual values

# Flask Environment (development or production)
FLASK_ENV=development

# Secret key for Flask sessions (generate a secure random key for production!)
# You can generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# Database URL (optional - defaults to ./data/fipe_data.db for SQLite)
# Leave commented out to use the default SQLite path in data/ directory
# DATABASE_URL=sqlite:///path/to/your/database.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost/fipe_db

# Default car to display on page load
DEFAULT_BRAND=Volkswagen
DEFAULT_MODEL=Gol
# Optional: pin a specific model year (e.g., "2021 Gasolina"). If empty, picks the most recent.
DEFAULT_YEAR=

# SQLAlchemy settings (optional)
SQLALCHEMY_ECHO=False

# ============================================================
# Google Analytics 4
# ============================================================
# Measurement ID from GA4 Data Stream (format: G-XXXXXXXXXX)
# Leave empty to disable analytics tracking
GA_MEASUREMENT_ID=
